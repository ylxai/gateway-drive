generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String               @id @default(uuid())
  name              String
  email             String               @unique
  passwordHash      String               @map("password_hash")
  status            String               @default("active")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  sessions          UserSession[]
  authHandoffs      AuthHandoff[]
  providerConfigs   ProviderConfig[]
  oauthStates       OauthState[]
  connectedAccounts ConnectedAccount[]
  s3StorageConfigs  S3StorageConfig[]
  files             File[]
  fileShares        FileShare[]
  filePreviewTokens FilePreviewToken[]
  folders           Folder[]
  uploadSessions    UploadSession[]
  auditLogs         AuditLog[]
  workspaceInvitesSent WorkspaceInvite[] @relation("WorkspaceInvitesSent")
  uploadRoutingPolicy  UploadRoutingPolicy?
  apiKeys           ApiKey[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  name       String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @unique @map("key_hash")
  scopes     Json
  status     String    @default("active")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status, createdAt])
  @@map("api_keys")
}

model UploadRoutingPolicy {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  mode               String   @default("most_available")
  priorityAccountIds Json     @map("priority_account_ids")
  roundRobinCursor   Int      @default(0) @map("round_robin_cursor")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_routing_policies")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  refreshTokenHash String    @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("user_sessions")
}

model AuthHandoff {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_handoffs")
}

model ProviderConfig {
  id                    String             @id @default(uuid())
  userId                String?            @map("user_id")
  provider              String
  clientIdEncrypted     String             @map("client_id_encrypted")
  clientSecretEncrypted String             @map("client_secret_encrypted")
  redirectUri           String             @map("redirect_uri")
  scopes                Json
  status                String             @default("active")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  user                  User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  oauthStates           OauthState[]
  connectedAccounts     ConnectedAccount[]

  @@index([userId])
  @@index([provider])
  @@map("provider_configs")
}

model OauthState {
  id               String         @id @default(uuid())
  userId           String?        @map("user_id")
  providerConfigId String         @map("provider_config_id")
  flow             String         @default("connect")
  stateHash        String         @unique @map("state_hash")
  expiresAt        DateTime       @map("expires_at")
  usedAt           DateTime?      @map("used_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConfig   ProviderConfig @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("oauth_states")
}

model ConnectedAccount {
  id                    String          @id @default(uuid())
  userId                String          @map("user_id")
  providerConfigId      String?         @map("provider_config_id")
  provider              String
  providerAccountId     String          @map("provider_account_id")
  email                 String
  displayName           String?         @map("display_name")
  avatarUrl             String?         @map("avatar_url")
  accessTokenEncrypted  String?         @map("access_token_encrypted")
  refreshTokenEncrypted String?         @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime?       @map("token_expires_at")
  scopes                Json
  status                String          @default("connected")
  lastError             String?         @map("last_error")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")
  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerConfig        ProviderConfig? @relation(fields: [providerConfigId], references: [id], onDelete: Cascade)
  storageAccount        StorageAccount?
  files                 File[]
  folders               Folder[]
  uploadSessions        UploadSession[]
  s3StorageConfig       S3StorageConfig?

  @@unique([userId, provider, providerAccountId])
  @@index([userId])
  @@index([userId, status, createdAt])
  @@map("connected_accounts")
}

model S3StorageConfig {
  id                       String           @id @default(uuid())
  userId                   String           @map("user_id")
  connectedAccountId       String           @unique @map("connected_account_id")
  name                     String
  bucket                   String
  region                   String
  endpoint                 String?
  accessKeyIdEncrypted     String           @map("access_key_id_encrypted")
  secretAccessKeyEncrypted String           @map("secret_access_key_encrypted")
  forcePathStyle           Boolean          @default(false) @map("force_path_style")
  prefix                   String           @default("9drive")
  quotaBytes               BigInt?          @map("quota_bytes")
  status                   String           @default("active")
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount         ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("s3_storage_configs")
}

model StorageAccount {
  id                 String           @id @default(uuid())
  connectedAccountId String           @unique @map("connected_account_id")
  totalBytes         BigInt?          @map("total_bytes")
  usedBytes          BigInt           @default(0) @map("used_bytes")
  availableBytes     BigInt?          @map("available_bytes")
  trashBytes         BigInt?          @map("trash_bytes")
  lastSyncedAt       DateTime?        @map("last_synced_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@map("storage_accounts")
}

model File {
  id                 String           @id @default(uuid())
  userId             String           @map("user_id")
  connectedAccountId String           @map("connected_account_id")
  folderId           String?          @map("folder_id")
  provider           String
  providerFileId     String           @map("provider_file_id")
  name               String
  mimeType           String           @map("mime_type")
  sizeBytes          BigInt           @map("size_bytes")
  checksum           String?
  status             String           @default("active")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  deletedAt          DateTime?        @map("deleted_at")
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  connectedAccount   ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)
  folder             Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  shares             FileShare[]
  previewTokens      FilePreviewToken[]

  @@index([userId])
  @@index([userId, status, createdAt])
  @@index([userId, status, folderId, createdAt])
  @@index([connectedAccountId])
  @@index([folderId])
  @@index([providerFileId])
  @@map("files")
}

model FileShare {
  id        String    @id @default(uuid())
  fileId    String    @map("file_id")
  userId    String    @map("user_id")
  token     String?   @unique
  tokenHash String    @unique @map("token_hash")
  enabled   Boolean   @default(true)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  file      File      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@index([userId, enabled, createdAt])
  @@index([fileId, userId, enabled, createdAt])
  @@map("file_shares")
}

model FilePreviewToken {
  id        String   @id @default(uuid())
  fileId    String   @map("file_id")
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([userId])
  @@map("file_preview_tokens")
}

model Folder {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  parentId           String?           @map("parent_id")
  connectedAccountId String?           @map("connected_account_id")
  provider           String            @default("google_drive")
  providerFolderId   String?           @map("provider_folder_id")
  name               String
  color              String            @default("text-blue-500")
  iconUrl            String?           @map("icon_url")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent             Folder?           @relation("FolderChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children           Folder[]          @relation("FolderChildren")
  connectedAccount   ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: SetNull)
  files              File[]
  uploadSessions     UploadSession[]    @relation("UploadSessionFolder")

  @@index([userId])
  @@index([userId, deletedAt, updatedAt])
  @@index([userId, deletedAt, parentId, updatedAt])
  @@index([parentId])
  @@index([connectedAccountId])
  @@map("folders")
}

model UploadSession {
  id                       String            @id @default(uuid())
  userId                   String            @map("user_id")
  targetConnectedAccountId String?           @map("target_connected_account_id")
  folderId                 String?           @map("folder_id")
  fileName                 String            @map("file_name")
  mimeType                 String            @map("mime_type")
  sizeBytes                BigInt            @map("size_bytes")
  status                   String
  googleSessionUri         String?           @map("google_session_uri")
  errorMessage             String?           @map("error_message")
  createdAt                DateTime          @default(now()) @map("created_at")
  completedAt              DateTime?         @map("completed_at")
  user                     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetConnectedAccount   ConnectedAccount? @relation(fields: [targetConnectedAccountId], references: [id], onDelete: SetNull)
  folder                   Folder?           @relation("UploadSessionFolder", fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@map("upload_sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("audit_logs")
}

model WorkspaceInvite {
  id           String    @id @default(uuid())
  inviterId    String    @map("inviter_id")
  inviteeEmail String    @map("invitee_email")
  targetType   String    @default("file") @map("target_type")
  targetId     String    @default("") @map("target_id")
  role         String    @default("viewer")
  status       String    @default("pending")
  revokedAt    DateTime? @map("revoked_at")
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  inviter      User      @relation("WorkspaceInvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)

  @@unique([inviterId, inviteeEmail, targetType, targetId], map: "workspace_invites_target_unique")
  @@index([inviteeEmail])
  @@index([targetType, targetId])
  @@map("workspace_invites")
}
